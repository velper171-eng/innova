datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Patient {
  id              Int              @id @default(autoincrement())
  name            String
  birthdate       String
  gender          String           // "male" or "female"
  email           String?
  phone           String?
  password        String?
  country         String?
  sport           String?
  createdAt       DateTime         @default(now())
  evaluations     Evaluation[]
  supplements     Supplement[]
  cycles          SupplementCycle[]
  workoutSchedule WorkoutSchedule?
  postureJobs     PostureAnalysisJob[]
  calorieLogs     CalorieLog[]
  trainingPlans   TrainingPlan[]
  
  creatorId       Int?
  creator         Patient?         @relation("UserAthletes", fields: [creatorId], references: [id], onDelete: Cascade)
  athletes        Patient[]        @relation("UserAthletes")
}

model Evaluation {
  id                   Int      @id @default(autoincrement())
  patientId            Int
  patient              Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  date                 String
  weight               Float    // in kg
  height               Float    // in cm
  age                  Int
  
  // Skinfolds (Pliegues cutáneos in mm)
  skinfoldTriceps      Float
  skinfoldBiceps       Float
  skinfoldSubescapular Float
  skinfoldSupraspinale Float
  skinfoldCrestaIliaca Float    @default(0.0)
  skinfoldAbdominal    Float
  skinfoldThigh        Float
  skinfoldCalf         Float

  // Perimeters (Perímetros in cm)
  girthArm             Float
  girthArmRelaxed      Float    @default(0.0)
  girthArmContracted   Float    @default(0.0)
  girthWaist           Float    @default(0.0)
  girthHip             Float    @default(0.0)
  girthThigh           Float    @default(0.0)
  girthCalf            Float

  // Diameters (Diámetros in cm)
  diameterHumerus      Float
  diameterBiestiloideo Float    @default(0.0)
  diameterFemur        Float

  // Calculated Results
  density              Float    // Body Density (Db)
  bodyFat              Float    // Siri Body Fat %
  endomorphy           Float
  mesomorphy           Float
  ectomorphy           Float
  xCoord               Float    // X coordinate on Somatochart
  yCoord               Float    // Y coordinate on Somatochart
  
  createdAt            DateTime @default(now())
}

model Supplement {
  id                Int               @id @default(autoincrement())
  patientId         Int
  patient           Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name              String            // e.g. "Creatina Monohidratada"
  brand             String?           // e.g. "Evolufit"
  totalCapacity     Float             // e.g. 300 (g) or 90 (caps)
  remainingQuantity Float             // e.g. 250 (g) or 80 (caps)
  unit              String            // "g", "caps", "scoops"
  purchaseLink      String?           // Purchase URL
  createdAt         DateTime          @default(now())
  cycles            SupplementCycle[]
}

model SupplementCycle {
  id           Int          @id @default(autoincrement())
  patientId    Int
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  supplementId Int?
  supplement   Supplement?  @relation(fields: [supplementId], references: [id], onDelete: SetNull)
  name         String       // e.g. "Ciclo Creatina"
  startDate    String       // YYYY-MM-DD
  endDate      String?      // YYYY-MM-DD
  isActive     Boolean      @default(true)
  phases       CyclePhase[]
  logs         IntakeLog[]
  createdAt    DateTime     @default(now())
}

model CyclePhase {
  id           Int             @id @default(autoincrement())
  cycleId      Int
  cycle        SupplementCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  name         String          // "Carga", "Mantenimiento", "Normal"
  durationDays Int
  dailyDose    Float           // in grams or units
  timingType   String          // "pre-workout", "post-workout", "morning", "night", "custom"
  customTime   String?         // "08:00"
}

model IntakeLog {
  id        Int             @id @default(autoincrement())
  cycleId   Int
  cycle     SupplementCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  date      String          // YYYY-MM-DD
  time      String          // HH:MM
  doseTaken Float
  status    String          // "taken", "skipped"
  createdAt DateTime        @default(now())
}

model WorkoutSchedule {
  id          Int     @id @default(autoincrement())
  patientId   Int     @unique
  patient     Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  workoutTime String  // "18:00"
  activeDays  String  // Comma-separated active days, e.g. "Monday,Wednesday,Friday"
}

model PostureAnalysisJob {
  id         Int      @id @default(autoincrement())
  patientId  Int
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  videoPath  String
  status     String   // "pending", "processing", "completed", "failed"
  progress   Int      @default(0)
  resultJson String?  // text containing frame-by-frame landmarks, angles, and alerts
  createdAt  DateTime @default(now())
}

model CalorieLog {
  id          Int      @id @default(autoincrement())
  patientId   Int
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  date        String   // YYYY-MM-DD
  foodName    String
  calories    Int
  protein     Float?
  carbs       Float?
  fat         Float?
  ingredients String?
  preparation String?
  imagePath   String?
  createdAt   DateTime @default(now())
}


// ─────────────────────────────────────────────
// TRAINING PLANS
// ─────────────────────────────────────────────

model TrainingPlan {
  id          Int           @id @default(autoincrement())
  patientId   Int
  patient     Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name        String        // e.g. "Plan Hipertrofia 4 días"
  goal        String        // "hypertrophy", "strength", "endurance", "fat_loss"
  daysPerWeek Int           @default(4)
  isActive    Boolean       @default(true)
  days        TrainingDay[]
  createdAt   DateTime      @default(now())
}

model TrainingDay {
  id         Int                @id @default(autoincrement())
  planId     Int
  plan       TrainingPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  dayIndex   Int                // 0=Mon, 1=Tue, ... 6=Sun
  name       String             // "Pierna - Hipertrofia"
  muscleGroup String            // "legs", "chest", "back", "shoulders", "arms", "full_body", "rest"
  exercises  TrainingExercise[]
}

model TrainingExercise {
  id          Int           @id @default(autoincrement())
  dayId       Int
  day         TrainingDay   @relation(fields: [dayId], references: [id], onDelete: Cascade)
  name        String        // "Sentadilla"
  sets        Int           @default(3)
  reps        String        @default("8-12")  // can be "8-12" or "30s"
  weight      Float?        // in kg, optional
  muscleGroup String        // primary muscle group for the diagram
  order       Int           @default(0)
  logs        ExerciseLog[]
}

model ExerciseLog {
  id         Int              @id @default(autoincrement())
  exerciseId Int
  exercise   TrainingExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  date       String           // YYYY-MM-DD
  completed  Boolean          @default(false)
  actualSets Int?
  actualReps String?
  actualWeight Float?
  createdAt  DateTime         @default(now())
}
