{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "server/vercel-entry.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["server/recommendedProducts.json", "recommendedProducts.json"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/vercel-entry.js"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "server/vercel-entry.js"
    },
    {
      "src": "/(.*)",
      "dest": "client/$1"
    }
  ]
}
